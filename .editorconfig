# EditorConfig is awesome: http://EditorConfig.org

# top-most EditorConfig file
root = true

# space indentation for Kotlin
[*.{kt,kts}]
indent_style = space
indent_size = 4
max_line_length = 120
continuation_indent_size = 4
insert_final_newline = false
ktlint_standard_filename = disabled
ktlint_standard_annotation = disabled
ktlint_standard_enum-entry-name-case = disabled
ktlint_standard_function-naming = disabled
ktlint_standard_function-signature = disabled
ktlint_standard_if-else-wrapping = disabled
ktlint_standard_wrapping = disabled
ktlint_standard_max-line-length = disabled
ktlint_standard_multiline-expression-wrapping = disabled
ktlint_standard_no-empty-first-line-in-method-block = disabled
ktlint_standard_package-name = disabled
ktlint_standard_property-naming = disabled
ktlint_standard_trailing-comma-on-call-site = disabled
ktlint_standard_trailing-comma-on-declaration-site = disabled
ktlint_standard_multiline-if-else = disabled
ktlint_standard_no-empty-first-line-in-class-body = disabled
ktlint_standard_parameter-list-wrapping = disabled
ktlint_standard_if-else-bracing = disabled
ktlint_standard_spacing-between-declarations-with-annotations = disabled
ktlint_standard_property-wrapping = disabled
ktlint_standard_indent = disabled
ktlint_standard_string-template-indent = disabled
ktlint_standard_value-parameter-comment = disabled
ktlint_standard_backing-property-naming = disabled
ktlint_standard_annotation-spacing = disabled
ktlint_standard_statement-wrapping = disabled
ktlint_standard_block-comment-initial-star-alignment = disabled
ktlint_standard_no-empty-file = disabled
ktlint_standard_class-signature = disabled
ktlint_standard_blank-line-before-declaration = disabled
ktlint_standard_class-naming = disabled
ktlint_standard_function-type-reference-spacing = disabled

# Ktlint 4.3.0 > 4.4.1
ktlint_standard_function-expression-body = disabled # Avoids validation of function body being replaced by an expression
ktlint_standard_chain-method-continuation = disabled # Avoids validation of line breaks before '.'
ktlint_standard_condition-wrapping = disabled # Avoids validation of line breaks before operands in conditions
ktlint_standard_function-literal = disabled # Avoids validation of line breaks in function literals
ktlint_standard_paren-spacing = disabled # Avoids validation of spacing before "("
ktlint_standard_binary-expression-wrapping = disabled # Avoids validation of line breaks in binary expressions
ktlint_standard_multiline-loop = disabled # Avoids validation of mandatory braces in multiline loops
ktlint_standard_final-newline = disabled # Ignore redundant newline validation at the end of file
# Ktlint 5.1.1 disabled rules
ktlint_standard_function-return-type-spacing = disabled
ktlint_standard_parameter-list-spacing = disabled
